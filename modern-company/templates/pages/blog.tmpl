{{define "content"}}
<!-- Page Banner -->
<section class="page-banner page-banner-blog">
    <span class="banner-watermark">{{T $.Ctx "page_title_news_blog"}}</span>
    <div class="container">
        <span class="section-label">{{T $.Ctx "page_label_latest_news"}}</span>
        <h1>{{T $.Ctx "page_title_news_blog"}}</h1>
        <p class="banner-subtitle">Industry insights, technical guides, and company news</p>
        <div class="breadcrumb">
            <a href="{{langPrefixURL $.Ctx "/"}}">{{T $.Ctx "nav_home"}}</a> <span>/</span> <span>{{T $.Ctx "nav_news"}}</span>
        </div>
    </div>
    <div class="page-banner-accent"></div>
</section>

<section class="section">
    <div class="container">
        <!-- Category Filter -->
        <div class="blog-filter">
            <a href="{{langPrefixURL $.Ctx (archiveURL "post")}}" class="filter-btn {{if eq .ActiveCat ""}}active{{end}}">{{T $.Ctx "filter_all"}}</a>
            {{range .Categories}}
            <a href="{{langPrefixURL $.Ctx (archiveURL "post")}}?category={{.Slug}}" class="filter-btn {{if eq $.ActiveCat .Slug}}active{{end}}">{{.Name}}</a>
            {{end}}
        </div>

        <!-- Post Grid -->
        <div class="blog-grid">
            {{range .Posts}}
            <article class="blog-card">
                <div class="blog-card-image">
                    {{if .ImageURL}}
                    {{responsiveImage .ImageURL .Title "" "(max-width: 768px) 100vw, 33vw" "lazy"}}
                    {{else}}
                    <div class="product-placeholder placeholder-sm">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                    </div>
                    {{end}}
                </div>
                <div class="blog-card-body">
                    <div class="blog-card-meta">
                        <span class="blog-category">{{.Category.Name}}</span>
                        <time>{{formatDate .PublishedAt}}</time>
                    </div>
                    <h3>{{.Title}}</h3>
                    <p>{{truncate .Excerpt 150}}</p>
                    <a href="{{langPrefixURL $.Ctx (contentURL . "post")}}" class="card-link">{{T $.Ctx "btn_read_more"}}</a>
                </div>
            </article>
            {{end}}
        </div>

        {{if eq (len .Posts) 0}}
        <div class="text-center" style="padding: 3rem 0;">
            <p>{{T $.Ctx "empty_no_posts_category"}}</p>
            <a href="{{langPrefixURL $.Ctx (archiveURL "post")}}" class="btn btn-secondary">{{T $.Ctx "btn_view_all_posts"}}</a>
        </div>
        {{end}}
    </div>
</section>
{{end}}
