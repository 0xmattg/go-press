{{define "content"}}
<!-- Page Banner -->
<section class="page-banner page-banner-contact">
    <span class="banner-watermark">{{T $.Ctx "page_title_contact"}}</span>
    <div class="container">
        <span class="section-label">{{T $.Ctx "page_label_contact"}}</span>
        <h1>{{T $.Ctx "page_title_contact"}}</h1>
        <p class="banner-subtitle">Get in touch for a free consultation on your cleanroom project</p>
        <div class="breadcrumb">
            <a href="{{langPrefixURL $.Ctx "/"}}">{{T $.Ctx "nav_home"}}</a> <span>/</span> <span>{{T $.Ctx "page_title_contact"}}</span>
        </div>
    </div>
    <div class="page-banner-accent"></div>
</section>

<section class="section">
    <div class="container">
        <div class="contact-layout">
            <!-- Contact Info Cards -->
            <div class="contact-info-grid">
                <div class="contact-info-card">
                    <div class="contact-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    </div>
                    <h4>{{T $.Ctx "contact_card_address"}}</h4>
                    <p>{{.Settings.company_address}}</p>
                </div>
                <div class="contact-info-card">
                    <div class="contact-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    </div>
                    <h4>{{T $.Ctx "contact_card_phone"}}</h4>
                    <p>{{.Settings.company_phone}}</p>
                </div>
                <div class="contact-info-card">
                    <div class="contact-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    </div>
                    <h4>{{T $.Ctx "contact_card_email"}}</h4>
                    <p>{{.Settings.company_email}}</p>
                </div>
                <div class="contact-info-card">
                    <div class="contact-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    <h4>{{T $.Ctx "contact_card_hours"}}</h4>
                    <p>Monday – Friday: 10 AM – 8 PM<br>Saturday: 10 AM – 6 PM<br>Sunday: Closed</p>
                </div>
            </div>

            <!-- Map Placeholder -->
            <div class="contact-map">
                <div class="map-placeholder">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    <p>Wuxi, Jiangsu, China</p>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="contact-form-wrapper">
                <div class="section-header centered">
                    <span class="section-label">{{T $.Ctx "btn_send_message"}}</span>
                    <h2>{{T $.Ctx "page_label_contact"}}</h2>
                </div>

                {{if .Success}}
                <div class="alert alert-success">
                    {{T $.Ctx "msg_contact_success"}}
                </div>
                {{end}}

                {{if .Error}}
                <div class="alert alert-error">
                    {{.Error}}
                </div>
                {{end}}

                <form action="/contact" method="POST" class="contact-form" id="contact-form">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="name">{{T $.Ctx "form_label_name"}}</label>
                            <input type="text" id="name" name="name" required maxlength="100" placeholder="{{T $.Ctx "form_placeholder_name"}}">
                        </div>
                        <div class="form-group">
                            <label for="email">{{T $.Ctx "form_label_email"}}</label>
                            <input type="email" id="email" name="email" required maxlength="255" placeholder="{{T $.Ctx "form_placeholder_email"}}">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="phone">{{T $.Ctx "form_label_phone"}}</label>
                        <input type="tel" id="phone" name="phone" maxlength="50" placeholder="{{T $.Ctx "form_placeholder_phone"}}">
                    </div>
                    <div class="form-group">
                        <label for="message">{{T $.Ctx "form_label_message"}}</label>
                        <textarea id="message" name="message" rows="6" required maxlength="2000" placeholder="{{T $.Ctx "form_placeholder_message"}}"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg">{{T $.Ctx "btn_send_message"}}</button>
                </form>
            </div>
        </div>
    </div>
</section>
{{end}}