<script>
// --- Tab state persistence (avoid jumping back to first tab after save/reload) ---
var ML_TAB_KEY = 'mlAdminTab';
var ML_SUBTAB_KEY = 'mlAdminSubtab';
var mlText = {
    saveFailed: {{toJSON (X $ "plugin.multilang.js.save_failed" "保存失败")}},
    languageRequired: {{toJSON (X $ "plugin.multilang.js.language_required" "请填写语言代码和名称")}},
    createTranslationTitle: {{toJSON (X $ "plugin.multilang.js.create_translation" "创建翻译")}},
    publishNow: {{toJSON (X $ "plugin.multilang.js.publish_now" "立即发布翻译（默认为草稿）")}},
    cancel: {{toJSON (X $ "plugin.multilang.js.cancel" "取消")}},
    confirmCreate: {{toJSON (X $ "plugin.multilang.js.confirm_create" "确认创建")}},
    cloneTo: {{toJSON (X $ "plugin.multilang.js.clone_to" "将克隆当前内容到 %s (%s)。")}},
    createFailed: {{toJSON (X $ "plugin.multilang.js.create_failed" "创建翻译失败")}},
    visibleCount: {{toJSON (X $ "plugin.multilang.js.visible_count" "显示 %d / %d 条")}},
    totalTranslations: {{toJSON (X $ "plugin.multilang.js.total_translations" "%d 条翻译")}}
};

function mlFormat(template) {
    var args = Array.prototype.slice.call(arguments, 1);
    return args.reduce(function(out, value) {
        return out.replace(/%[sdv]/, String(value));
    }, template);
}

function mlActivateTab(tabName) {
    if (!tabName) return;
    var btn = document.querySelector('.ts-tab[data-tab="' + tabName + '"]');
    var panel = document.getElementById('tab-' + tabName);
    if (!btn || !panel) return;
    document.querySelectorAll('.ts-tab').forEach(function(t) { t.classList.remove('active'); });
    document.querySelectorAll('.ts-panel').forEach(function(p) { p.classList.remove('active'); });
    btn.classList.add('active');
    panel.classList.add('active');
}

function mlActivateSubtab(subName) {
    if (!subName) return;
    var btn = document.querySelector('.ml-subtab[data-subtab="' + subName + '"]');
    var panel = document.getElementById('subtab-' + subName);
    if (!btn || !panel) return;
    document.querySelectorAll('.ml-subtab').forEach(function(t) { t.classList.remove('active'); });
    document.querySelectorAll('.ml-subtab-panel').forEach(function(p) { p.classList.remove('active'); });
    btn.classList.add('active');
    panel.classList.add('active');
}

// Tab switching
document.querySelectorAll('.ts-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
        mlActivateTab(tab.dataset.tab);
        try { sessionStorage.setItem(ML_TAB_KEY, tab.dataset.tab); } catch (e) {}
    });
});

// Sub-tab switching
document.querySelectorAll('.ml-subtab').forEach(function(tab) {
    tab.addEventListener('click', function() {
        mlActivateSubtab(tab.dataset.subtab);
        try { sessionStorage.setItem(ML_SUBTAB_KEY, tab.dataset.subtab); } catch (e) {}
    });
});

// Restore tab/subtab from sessionStorage on load (so save+reload stays put)
(function() {
    try {
        var t = sessionStorage.getItem(ML_TAB_KEY);
        var s = sessionStorage.getItem(ML_SUBTAB_KEY);
        if (t) mlActivateTab(t);
        if (s) mlActivateSubtab(s);
    } catch (e) {}
})();

// Menu assignment: collect all selects and POST via fetch
function saveMenuAssignment() {
    var form = new FormData();
    var selects = document.querySelectorAll('#menuAssignmentArea select[data-field]');
    selects.forEach(function(sel) {
        form.append(sel.getAttribute('data-field'), sel.value);
    });
    fetch('/admin/plugins/multi-language/menu-translate', {
        method: 'POST',
        body: form
    }).then(function(resp) {
        if (resp.redirected) {
            window.location.href = resp.url;
        } else {
            window.location.reload();
        }
    }).catch(function(err) {
        alert(mlText.saveFailed + ': ' + err.message);
    });
}

// Language row management
var langData = {
    'en': { name: 'English', flag: '🇬🇧' },
    'zh': { name: '中文', flag: '🇨🇳' },
    'ja': { name: '日本語', flag: '🇯🇵' },
    'ko': { name: '한국어', flag: '🇰🇷' },
    'fr': { name: 'Français', flag: '🇫🇷' },
    'de': { name: 'Deutsch', flag: '🇩🇪' },
    'es': { name: 'Español', flag: '🇪🇸' },
    'pt': { name: 'Português', flag: '🇵🇹' },
    'ru': { name: 'Русский', flag: '🇷🇺' },
    'ar': { name: 'العربية', flag: '🇸🇦' },
    'th': { name: 'ไทย', flag: '🇹🇭' },
    'vi': { name: 'Tiếng Việt', flag: '🇻🇳' }
};

// Auto-fill name and flag when language code is selected
document.getElementById('newLangCode').addEventListener('change', function() {
    var code = this.value;
    if (langData[code]) {
        document.getElementById('newLangName').value = langData[code].name;
        document.getElementById('newLangFlag').value = langData[code].flag;
    }
});

function addLanguageRow() {
    var code = document.getElementById('newLangCode').value;
    var name = document.getElementById('newLangName').value;
    var flag = document.getElementById('newLangFlag').value;
    if (!code || !name) {
        alert(mlText.languageRequired);
        return;
    }
    var tbody = document.getElementById('langRows');
    var idx = tbody.children.length;
    var row = document.createElement('tr');
    row.innerHTML = '<td>' + code + '<input type="hidden" name="plugin_multi-language_lang_' + idx + '_code" value="' + code + '"></td>'
        + '<td>' + flag + ' ' + name + '<input type="hidden" name="plugin_multi-language_lang_' + idx + '_name" value="' + name + '">'
        + '<input type="hidden" name="plugin_multi-language_lang_' + idx + '_flag" value="' + flag + '"></td>'
        + '<td>' + flag + '</td>'
        + '<td><input type="radio" name="plugin_multi-language_default_lang" value="' + code + '"></td>'
        + '<td><input type="number" name="plugin_multi-language_lang_' + idx + '_sort" value="' + idx + '" style="width:60px; padding:0.2rem 0.4rem; border:1px solid #d1d5db; border-radius:4px;"></td>'
        + '<td><select name="plugin_multi-language_lang_' + idx + '_active" style="padding:0.2rem 0.4rem; border:1px solid #d1d5db; border-radius:4px;"><option value="true" selected>{{X $ "plugin.multilang.ui.009" "启用"}}</option><option value="false">{{X $ "plugin.multilang.ui.010" "禁用"}}</option></select></td>';
    tbody.appendChild(row);

    // Reset inputs
    document.getElementById('newLangCode').value = '';
    document.getElementById('newLangName').value = '';
    document.getElementById('newLangFlag').value = '';
}

// Load existing languages into the table on page load
(function() {
    // Languages are now rendered server-side from the database.
    // This IIFE only initializes the settings map for other tab usage.
    var settings = {};
    {{range $key, $val := .Settings}}
    settings["{{$key}}"] = "{{$val}}";
    {{end}}
    window._pluginSettings = settings;
})();

// Content translation table filter by type
function filterTranslationTable() {
    var filter = document.getElementById('translationTypeFilter').value;
    var rows = document.querySelectorAll('.ml-trans-table tbody tr[data-type]');
    rows.forEach(function(row) {
        if (!filter || row.dataset.type === filter) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    });
}

// Create translation via fetch (avoid nested form issue) — opens a modal
// so the admin can choose whether to publish the cloned translation directly.
function createTranslation(contentID, targetLang, langName) {
    var modal = document.getElementById('mlTranslateModal');
    if (!modal) {
        modal = document.createElement('div');
        modal.id = 'mlTranslateModal';
        modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.45);display:flex;align-items:center;justify-content:center;z-index:9999;';
        modal.innerHTML = ''
            + '<div style="background:#fff;border-radius:8px;min-width:360px;max-width:90vw;padding:24px;box-shadow:0 12px 40px rgba(0,0,0,.25);">'
            + '  <h3 style="margin:0 0 12px 0;font-size:16px;">' + mlText.createTranslationTitle + '</h3>'
            + '  <p id="mlTranslateMsg" style="margin:0 0 16px 0;color:#374151;font-size:14px;line-height:1.5;"></p>'
            + '  <label style="display:flex;align-items:center;gap:8px;font-size:14px;color:#111827;cursor:pointer;margin-bottom:18px;">'
            + '    <input type="checkbox" id="mlTranslatePublish" style="width:16px;height:16px;">'
            + '    <span>' + mlText.publishNow + '</span>'
            + '  </label>'
            + '  <div style="display:flex;gap:8px;justify-content:flex-end;">'
            + '    <button type="button" id="mlTranslateCancel" class="btn btn-secondary">' + mlText.cancel + '</button>'
            + '    <button type="button" id="mlTranslateConfirm" class="btn btn-primary">' + mlText.confirmCreate + '</button>'
            + '  </div>'
            + '</div>';
        document.body.appendChild(modal);
    }
    var msg = modal.querySelector('#mlTranslateMsg');
    var pub = modal.querySelector('#mlTranslatePublish');
    pub.checked = false;
    msg.textContent = mlFormat(mlText.cloneTo, langName, targetLang);
    modal.style.display = 'flex';

    function close() {
        modal.style.display = 'none';
        modal.querySelector('#mlTranslateCancel').onclick = null;
        modal.querySelector('#mlTranslateConfirm').onclick = null;
    }

    modal.querySelector('#mlTranslateCancel').onclick = close;
    modal.querySelector('#mlTranslateConfirm').onclick = function() {
        var publish = pub.checked ? '1' : '0';
        close();
        var form = new FormData();
        form.append('content_id', contentID);
        form.append('target_lang', targetLang);
        form.append('publish', publish);
        fetch('/admin/plugins/multi-language/translate', {
            method: 'POST',
            body: form
        }).then(function(resp) {
            if (resp.redirected) {
                window.location.href = resp.url;
            } else {
                window.location.reload();
            }
        }).catch(function(err) {
            alert(mlText.createFailed + ': ' + err.message);
        });
    };
}

// String translation save via fetch
function saveStringTranslations() {
    var form = new FormData();
    var inputs = document.querySelectorAll('.ml-string-table input[name^="st_"]');
    inputs.forEach(function(input) {
        form.append(input.name, input.value);
    });
    fetch('/admin/plugins/multi-language/string-translate', {
        method: 'POST',
        body: form
    }).then(function(resp) {
        if (resp.redirected) {
            window.location.href = resp.url;
        } else {
            window.location.reload();
        }
    }).catch(function(err) {
        alert(mlText.saveFailed + ': ' + err.message);
    });
}

// String translation search filter
function filterStringTable() {
    var filter = document.getElementById('stringKeyFilter').value.toLowerCase();
    var rows = document.querySelectorAll('.ml-string-table tbody tr');
    var visible = 0;
    rows.forEach(function(row) {
        var key = (row.dataset.skey || '').toLowerCase();
        var text = row.textContent.toLowerCase();
        if (!filter || key.indexOf(filter) !== -1 || text.indexOf(filter) !== -1) {
            row.style.display = '';
            visible++;
        } else {
            row.style.display = 'none';
        }
    });
    var countEl = document.getElementById('stringKeyCount');
    if (countEl) {
        countEl.textContent = filter ? mlFormat(mlText.visibleCount, visible, rows.length) : mlFormat(mlText.totalTranslations, rows.length);
    }
}
// Init string key count
(function() {
    var rows = document.querySelectorAll('.ml-string-table tbody tr');
    var countEl = document.getElementById('stringKeyCount');
    if (countEl && rows.length) {
        countEl.textContent = mlFormat(mlText.totalTranslations, rows.length);
    }
})();

// Option translation save via fetch
function saveOptionTranslations() {
    var form = new FormData();
    var inputs = document.querySelectorAll('.ml-opt-table input[name^="ot_"]');
    inputs.forEach(function(input) {
        form.append(input.name, input.value);
    });
    fetch('/admin/plugins/multi-language/option-translate', {
        method: 'POST',
        body: form
    }).then(function(resp) {
        if (resp.redirected) {
            window.location.href = resp.url;
        } else {
            window.location.reload();
        }
    }).catch(function(err) {
        alert(mlText.saveFailed + ': ' + err.message);
    });
}
</script>
