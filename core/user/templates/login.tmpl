{{define "login"}}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex,nofollow">
    <title>Sign in | {{.SiteName}}</title>
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; min-height: 100vh; display: grid; place-items: center; padding: 24px; color: #17233c; background: #f3f6f9; font: 15px/1.5 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
        main { width: min(100%, 420px); padding: 32px; background: #fff; border: 1px solid #dce3ea; border-radius: 8px; box-shadow: 0 16px 40px rgba(24, 40, 64, .1); }
        h1 { margin: 0 0 8px; font-size: 24px; letter-spacing: 0; }
        p { margin: 0 0 24px; color: #5a6778; }
        a, button { width: 100%; min-height: 44px; display: flex; align-items: center; justify-content: center; border: 1px solid #c9d4df; border-radius: 6px; background: #fff; color: #17233c; font: inherit; font-weight: 650; text-decoration: none; cursor: pointer; }
        a:hover, button:hover { border-color: #268dcc; color: #167bb8; }
        .providers { display: grid; gap: 10px; }
        .empty { padding: 14px; border-radius: 6px; background: #f6f8fa; color: #5a6778; text-align: center; }
		.error { margin-bottom: 18px; padding: 12px 14px; border: 1px solid #efc9c5; border-radius: 6px; background: #fff5f4; color: #9d2f25; }
    </style>
</head>
<body>
<main>
    <h1>{{.SiteName}}</h1>
	{{if .Error}}<div class="error" role="alert">{{.Error}}</div>{{end}}
    {{if .User}}
    <p>Signed in as {{.User.DisplayName}}</p>
    <form method="post" action="/logout">
        <input type="hidden" name="return_to" value="{{.ReturnTo}}">
        <button type="submit">Sign out</button>
    </form>
    {{else}}
    <p>Choose a sign-in method.</p>
    {{if .Providers}}
    <div class="providers">
        {{range .Providers}}<a href="{{.URL}}">Continue with {{.Label}}</a>{{end}}
    </div>
    {{else}}
    <div class="empty">No sign-in methods are currently available.</div>
    {{end}}
    {{end}}
</main>
</body>
</html>
{{end}}
