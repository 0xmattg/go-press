{{define "content"}}
<section class="ff-page-hero ff-page-hero-blog" style="--hero-bg:url('https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=1600&h=820&fit=crop&q=82');">
    <span class="ff-hero-ghost">BUILDERS</span>
    <div class="ff-page-hero-inner">
        <span class="ff-kicker">{{T $.Ctx "page_label_latest_news"}}</span>
        <h1>{{T $.Ctx "page_title_news_blog"}}</h1>
        <span class="ff-hero-rule"></span>
        <p>Product notes, treasury thinking, and developer patterns for stable digital dollars.</p>
        <div class="ff-breadcrumb"><a href="{{langPrefixURL $.Ctx "/"}}">{{T $.Ctx "nav_home"}}</a><span>/</span><span>{{T $.Ctx "nav_news"}}</span></div>
    </div>
</section>

<section class="ff-section">
    <div class="ff-filter-row">
        <a href="{{langPrefixURL $.Ctx (archiveURL "post")}}" class="{{if eq .ActiveCat ""}}active{{end}}">{{T $.Ctx "filter_all"}}</a>
        {{range .Categories}}
        <a href="{{langPrefixURL $.Ctx (archiveURL "post")}}?category={{.Slug}}" class="{{if eq $.ActiveCat .Slug}}active{{end}}">{{.Name}}</a>
        {{end}}
    </div>

    {{if .Posts}}
    <div class="ff-blog-grid">
        {{range .Posts}}
        <article class="ff-blog-card">
            <a class="ff-blog-media" href="{{langPrefixURL $.Ctx (contentURL . "post")}}">
                {{if .ImageURL}}{{responsiveImage .ImageURL .Title "" "(max-width: 768px) 100vw, 33vw" "lazy"}}{{else}}<span class="ff-card-icon">◇</span>{{end}}
            </a>
            <div class="ff-blog-body">
                <div class="ff-blog-meta">
                    {{if .Category.Name}}<span>{{.Category.Name}}</span>{{end}}
                    <time>{{formatDate .PublishedAt}}</time>
                </div>
                <h3><a href="{{langPrefixURL $.Ctx (contentURL . "post")}}">{{.Title}}</a></h3>
                <p>{{truncate .Excerpt 150}}</p>
                <a class="ff-card-arrow" href="{{langPrefixURL $.Ctx (contentURL . "post")}}">{{T $.Ctx "btn_read_more"}}</a>
            </div>
        </article>
        {{end}}
    </div>
    {{else}}
    <div class="ff-empty-state">
        <p>{{T $.Ctx "empty_no_posts_category"}}</p>
        <a class="ff-outline-btn" href="{{langPrefixURL $.Ctx (archiveURL "post")}}">{{T $.Ctx "btn_view_all_posts"}}</a>
    </div>
    {{end}}
</section>
{{end}}
