{{define "content"}}
<section class="as-detail-hero">
    <div class="as-container">
        <div class="as-detail-grid">
            <div>
                <p class="as-kicker as-kicker-light">Service</p>
                <h1>{{.Service.Title}}</h1>
                <p>{{if .Service.Excerpt}}{{.Service.Excerpt}}{{else}}{{truncate (stripTags .Service.Description) 220}}{{end}}</p>
                <div class="as-tags">{{range .Tags}}<a href="{{langPrefixURL $.Ctx (printf "/tag/%s" .Slug)}}">{{.Name}}</a>{{end}}</div>
            </div>
            <figure>{{if .Service.ImageURL}}{{responsiveImage .Service.ImageURL .Service.Title "" "(max-width: 768px) 100vw, 50vw" "lazy"}}{{end}}</figure>
        </div>
    </div>
</section>
<section class="as-section"><div class="as-container as-detail-body"><article class="as-richtext">{{safeHTML .Service.Description}}</article><aside class="as-side-panel"><h3>Related</h3>{{range .Related}}<a href="{{langPrefixURL $.Ctx (printf "/services/%s" .Slug)}}">{{.Title}}</a>{{end}}</aside></div></section>
{{end}}
