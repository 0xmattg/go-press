{{define "content"}}
<section class="as-detail-hero">
    <div class="as-container">
        <div class="as-detail-grid">
            <div>
                <p class="as-kicker as-kicker-light">{{if .Post.PublishedAt}}{{formatDate .Post.PublishedAt}}{{end}} {{if .Post.Category.Name}}/ {{.Post.Category.Name}}{{end}}</p>
                <h1>{{.Post.Title}}</h1>
                <p>{{if .Post.Excerpt}}{{.Post.Excerpt}}{{else}}{{truncate (stripTags .Post.Content) 220}}{{end}}</p>
                <div class="as-tags">{{range .Post.Tags}}<a href="{{langPrefixURL $.Ctx (printf "/tag/%s" .Slug)}}">{{.Name}}</a>{{end}}</div>
            </div>
            <figure>{{if .Post.ImageURL}}{{responsiveImage .Post.ImageURL .Post.Title "" "(max-width: 768px) 100vw, 50vw" "lazy"}}{{end}}</figure>
        </div>
    </div>
</section>
<section class="as-section"><div class="as-container as-detail-body"><article class="as-richtext">{{safeHTML .Post.Content}}</article><aside class="as-side-panel"><h3>Related</h3>{{range .Related}}<a href="{{langPrefixURL $.Ctx (printf "/blog/%s" .Slug)}}">{{.Title}}</a>{{end}}<h3>Categories</h3>{{range .Categories}}<a href="{{langPrefixURL $.Ctx (printf "/category/%s" .Slug)}}">{{.Name}}</a>{{end}}</aside></div></section>
{{end}}
