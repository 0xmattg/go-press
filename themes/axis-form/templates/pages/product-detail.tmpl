{{define "content"}}
<section class="af-detail-hero">
    <span>Process Module</span>
    <h1>{{.Product.Title}}</h1>
    <p>{{.Product.Excerpt}}</p>
</section>

<section class="af-detail-layout">
    <article class="af-detail-card">
        {{if .Product.ImageURL}}<div class="af-detail-media">{{responsiveImagePriority .Product.ImageURL .Product.Title "" "(max-width: 768px) 100vw, 62vw"}}</div>{{end}}
        <div class="af-richtext">{{safeHTML .Product.Description}}</div>
    </article>
    <aside class="af-detail-aside">
        <h3>Related stages</h3>
        {{range .Related}}<a href="{{langPrefixURL $.Ctx (printf "/products/%s" .Slug)}}">{{.Title}} <span>→</span></a>{{end}}
    </aside>
</section>
{{end}}
