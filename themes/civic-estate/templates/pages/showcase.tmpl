{{define "content"}}
<section class="ce-page-hero">
    <span>Listings</span>
    <h1>Selected commercial spaces ready for deeper review.</h1>
    <p>Office listings, retail corridors, redevelopment sites, and tenant-ready opportunities across priority markets.</p>
</section>

<section class="ce-showcase-grid">
    {{range $i, $item := .Showcases}}
    <a class="ce-showcase-card" href="{{langPrefixURL $.Ctx (contentURL $item "showcase")}}">
        <div class="ce-card-media">
            {{if $item.ImageURL}}{{responsiveImage $item.ImageURL $item.Title "" "(max-width: 768px) 100vw, 33vw" "lazy"}}{{end}}
        </div>
        <div>
            <h2>{{$item.Title}}</h2>
            <p>{{truncate (stripTags $item.Description) 120}}</p>
            {{if $item.Location}}<span>{{$item.Location}}</span>{{end}}
        </div>
    </a>
    {{end}}
</section>
{{end}}
