{{define "content"}}
<section class="ce-detail-hero">
    <span>Journal</span>
    <h1>{{.Post.Title}}</h1>
    <p>{{formatDateTime .Post.PublishedAt}}</p>
</section>

<section class="ce-detail-layout">
    <article class="ce-detail-card">
        {{if .Post.ImageURL}}<div class="ce-detail-media">{{responsiveImagePriority .Post.ImageURL .Post.Title "" "(max-width: 768px) 100vw, 62vw"}}</div>{{end}}
        <div class="ce-richtext">{{safeHTML .Post.Content}}</div>
    </article>
    <aside class="ce-detail-aside">
        <h3>Related articles</h3>
        {{range .Related}}<a href="{{langPrefixURL $.Ctx (contentURL . "post")}}">{{.Title}} <span>→</span></a>{{end}}
    </aside>
</section>
{{end}}
