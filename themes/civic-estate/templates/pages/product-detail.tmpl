{{define "content"}}
<section class="ce-detail-hero">
    <span>Property Type</span>
    <h1>{{.Product.Title}}</h1>
    <p>{{.Product.Excerpt}}</p>
</section>

<section class="ce-detail-layout">
    <article class="ce-detail-card">
        {{if .Product.ImageURL}}<div class="ce-detail-media">{{responsiveImagePriority .Product.ImageURL .Product.Title "" "(max-width: 768px) 100vw, 62vw"}}</div>{{end}}
        <div class="ce-richtext">{{safeHTML .Product.Description}}</div>
    </article>
    <aside class="ce-detail-aside">
        <h3>Related types</h3>
        {{range .Related}}<a href="{{langPrefixURL $.Ctx (contentURL . "product")}}">{{.Title}} <span>→</span></a>{{end}}
    </aside>
</section>
{{end}}
