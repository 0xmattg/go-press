{{define "content"}}
<!-- Page Banner -->
<section class="page-banner page-banner-services">
    <span class="banner-watermark">{{T $.Ctx "page_title_services"}}</span>
    <div class="container">
        <span class="section-label">{{T $.Ctx "page_label_services"}}</span>
        <h1>{{T $.Ctx "page_title_services"}}</h1>
        <p class="banner-subtitle">End-to-end cleanroom solutions — from design to validation and beyond</p>
        <div class="breadcrumb">
            <a href="{{langPrefixURL $.Ctx "/"}}">{{T $.Ctx "nav_home"}}</a> <span>/</span> <span>{{T $.Ctx "page_title_services"}}</span>
        </div>
    </div>
    <div class="page-banner-accent"></div>
</section>

<section class="section">
    <div class="container">
        <div class="services-layout">
            <div class="services-main">
                <div class="section-header" style="text-align:left; margin-bottom:36px;">
                    <span class="section-label">{{T $.Ctx "section_what_offer"}}</span>
                    <h2>{{T $.Ctx "section_professional_services"}}</h2>
                    <p>Comprehensive cleanroom engineering services covering the full project lifecycle</p>
                </div>
                <div class="service-list">
                    {{range .Services}}
                    <div class="service-card-full">
                        <div class="service-image">
                            <a href="{{langPrefixURL $.Ctx (printf "/services/%s" .Slug)}}" class="service-image-link" aria-label="Learn more about {{.Title}}">
                                {{if .ImageURL}}
                                {{responsiveImage .ImageURL .Title "" "(max-width: 768px) 100vw, 33vw" "lazy"}}
                                {{else}}
                                <div class="product-placeholder">
                                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                                </div>
                                {{end}}
                            </a>
                        </div>
                        <div class="service-info">
                            <h3><a href="{{langPrefixURL $.Ctx (printf "/services/%s" .Slug)}}">{{.Title}}</a></h3>
                            {{if .Excerpt}}<p class="service-excerpt">{{.Excerpt}}</p>{{end}}
                            {{if .Description}}<p class="service-summary">{{stripTags .Description}}</p>{{end}}
                            <div class="service-actions">
                                <a href="{{langPrefixURL $.Ctx (printf "/services/%s" .Slug)}}" class="btn btn-secondary">{{T $.Ctx "btn_learn_more"}}</a>
                            </div>
                        </div>
                    </div>
                    {{end}}
                </div>
            </div>
            <aside class="services-sidebar">
                <div class="sidebar-widget">
                    <h4>{{T $.Ctx "section_recent_articles"}}</h4>
                    <ul class="sidebar-posts">
                        {{range .PageData.RecentPosts}}
                        <li>
                            <a href="{{langPrefixURL $.Ctx "/blog"}}">{{.Title}}</a>
                            <time>{{formatDate .PublishedAt}}</time>
                        </li>
                        {{end}}
                    </ul>
                </div>
                <div class="sidebar-widget">
                    <h4>{{T $.Ctx "sidebar_tags"}}</h4>
                    <div class="tag-cloud">
                        {{range .Tags}}
                        <a href="{{langPrefixURL $.Ctx "/blog"}}?category={{.Slug}}" class="tag">{{.Name}}</a>
                        {{end}}
                    </div>
                </div>
                <div class="sidebar-widget sidebar-cta">
                    <h4>{{T $.Ctx "btn_get_free_quote"}}</h4>
                    <p>Contact us for a free consultation on your cleanroom project.</p>
                    <a href="{{langPrefixURL $.Ctx "/contact"}}" class="btn btn-primary">{{T $.Ctx "btn_contact_us"}}</a>
                </div>
            </aside>
        </div>
    </div>
</section>
{{end}}
