{{define "content"}}
<!-- Page Banner -->
<section class="page-banner page-banner-products">
    <span class="banner-watermark">{{T $.Ctx "page_title_products"}}</span>
    <div class="container">
        <span class="section-label">{{T $.Ctx "page_label_products"}}</span>
        <h1>{{T $.Ctx "page_title_products"}}</h1>
        <p class="banner-subtitle">Cleanroom equipment engineered and manufactured in Wuxi, China</p>
        <div class="breadcrumb">
            <a href="{{langPrefixURL $.Ctx "/"}}">{{T $.Ctx "nav_home"}}</a> <span>/</span> <span>{{T $.Ctx "page_title_products"}}</span>
        </div>
    </div>
    <div class="page-banner-accent"></div>
</section>

<section class="section">
    <div class="container">
        <div class="section-header centered">
            <span class="section-label">{{T $.Ctx "section_equipment_systems"}}</span>
            <h2>{{T $.Ctx "section_product_lines"}}</h2>
            <p>High-quality cleanroom and air purification equipment — from HEPA filters to complete wall-panel systems</p>
        </div>
        <div class="product-list">
            {{range .Products}}
            <div class="product-card">
                <div class="product-image">
                    <a href="{{langPrefixURL $.Ctx (printf "/products/%s" .Slug)}}" class="product-image-link" aria-label="View details for {{.Title}}">
                        {{if .ImageURL}}
                        {{responsiveImage .ImageURL .Title "" "(max-width: 768px) 100vw, 33vw" "lazy"}}
                        {{else}}
                        <div class="product-placeholder">
                            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                        </div>
                        {{end}}
                    </a>
                </div>
                <div class="product-info">
                    <h3><a href="{{langPrefixURL $.Ctx (printf "/products/%s" .Slug)}}">{{.Title}}</a></h3>
                    {{if .Excerpt}}<p class="product-excerpt">{{.Excerpt}}</p>{{end}}
                    {{if .Description}}<p class="product-summary">{{stripTags .Description}}</p>{{end}}
                    <div class="product-actions">
                        <a href="{{langPrefixURL $.Ctx (printf "/products/%s" .Slug)}}" class="btn btn-secondary">{{T $.Ctx "btn_view_details"}}</a>
                    </div>
                </div>
            </div>
            {{end}}
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="section cta-section text-center">
    <div class="container">
        <h2>Need a Custom Solution?</h2>
        <p>We manufacture to your exact specifications — from single filters to complete turnkey cleanroom equipment packages.</p>
        <a href="{{langPrefixURL $.Ctx "/contact"}}" class="btn btn-primary btn-lg">Request a Quote</a>
    </div>
</section>
{{end}}
