{{define "content"}}
<!-- Page Banner -->
<section class="page-banner page-banner-archive">
    <span class="banner-watermark">{{if eq .TaxonomyType "category"}}{{T $.Ctx "archive_label_category"}}{{else}}{{T $.Ctx "archive_label_tag"}}{{end}}</span>
    <div class="container">
        <span class="section-label">{{if eq .TaxonomyType "category"}}{{T $.Ctx "archive_label_category"}}{{else}}{{T $.Ctx "archive_label_tag"}}{{end}}</span>
        <h1>{{.TermName}}</h1>
        <p class="banner-subtitle">{{.Total}} {{T $.Ctx "archive_items_found"}}</p>
        <div class="breadcrumb">
            <a href="{{langPrefixURL $.Ctx "/"}}">{{T $.Ctx "nav_home"}}</a> <span>/</span>
            <span>{{if eq .TaxonomyType "category"}}{{T $.Ctx "archive_label_category"}}{{else}}{{T $.Ctx "archive_label_tag"}}{{end}}</span> <span>/</span>
            <span>{{.TermName}}</span>
        </div>
    </div>
    <div class="page-banner-accent"></div>
</section>

<section class="section">
    <div class="container">
        {{if .Items}}
        <div class="archive-grid">
            {{range .Items}}
            <article class="archive-card">
                <div class="archive-card-image">
                    {{if .ImageURL}}
                    <a href="{{.DetailURL}}">
                        {{responsiveImage .ImageURL .Title "" "(max-width: 768px) 100vw, 33vw" "lazy"}}
                    </a>
                    {{else}}
                    <a href="{{.DetailURL}}" class="product-placeholder placeholder-sm">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                    </a>
                    {{end}}
                </div>
                <div class="archive-card-body">
                    <div class="archive-card-meta">
                        <span class="archive-type-badge badge-{{.ContentType}}">{{.TypeLabel}}</span>
                    </div>
                    <h3><a href="{{.DetailURL}}">{{.Title}}</a></h3>
                    {{if .Excerpt}}
                    <p>{{.Excerpt}}</p>
                    {{end}}
                    <a href="{{.DetailURL}}" class="read-more">{{T $.Ctx "btn_view_details"}} &rarr;</a>
                </div>
            </article>
            {{end}}
        </div>
        {{else}}
        <div class="empty-state">
            <p>{{T $.Ctx "empty_no_content"}}</p>
        </div>
        {{end}}
    </div>
</section>
{{end}}
