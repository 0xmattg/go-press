{{define "content"}}
<!-- Page Banner -->
<section class="page-banner page-banner-services">
    <span class="banner-watermark">{{T $.Ctx "page_title_services"}}</span>
    <div class="container">
        <span class="section-label">{{T $.Ctx "page_label_service_details"}}</span>
        <h1>{{.Service.Title}}</h1>
        <div class="breadcrumb">
            <a href="{{langPrefixURL $.Ctx "/"}}">{{T $.Ctx "nav_home"}}</a> <span>/</span> <a href="{{langPrefixURL $.Ctx "/services"}}">{{T $.Ctx "page_title_services"}}</a> <span>/</span> <span>{{.Service.Title}}</span>
        </div>
    </div>
    <div class="page-banner-accent"></div>
</section>

<section class="section">
    <div class="container">
        <div class="detail-layout">
            <div class="detail-image">
                {{if .Service.ImageURL}}
                {{responsiveImagePriority .Service.ImageURL .Service.Title "" "(max-width: 768px) 100vw, 70vw"}}
                {{else}}
                <div class="product-placeholder placeholder-lg">
                    <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                </div>
                {{end}}
            </div>
            <div class="detail-content">
                <h2>{{.Service.Title}}</h2>
                <div class="detail-body">
                    {{safeHTML .Service.Description}}
                </div>
                {{if .Tags}}
                <div class="post-tags">
                    <strong>{{T $.Ctx "sidebar_tags"}}:</strong>
                    {{range .Tags}}<a href="{{langPrefixURL $.Ctx (printf "/tag/%s" .Slug)}}" class="tag-link">{{.Name}}</a>{{end}}
                </div>
                {{end}}
                <div class="detail-actions">
                    <a href="{{langPrefixURL $.Ctx "/contact"}}" class="btn btn-primary">{{T $.Ctx "btn_contact_us"}}</a>
                    <a href="{{langPrefixURL $.Ctx "/services"}}" class="btn btn-outline">{{T $.Ctx "btn_back_services"}}</a>
                </div>
            </div>
        </div>
    </div>
</section>

{{if .Related}}
<section class="section section-gray">
    <div class="container">
        <div class="text-center" style="margin-bottom:40px;">
            <span class="section-label">{{T $.Ctx "section_may_like"}}</span>
            <h2>{{T $.Ctx "section_other_services"}}</h2>
        </div>
        <div class="related-card-grid">
            {{range .Related}}
            <a href="{{langPrefixURL $.Ctx (printf "/services/%s" .Slug)}}" class="related-card">
                <div class="related-card-image">
                    {{if .ImageURL}}
                    {{responsiveImage .ImageURL .Title "" "(max-width: 768px) 100vw, 33vw" "lazy"}}
                    {{else}}
                    <div class="product-placeholder placeholder-sm">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                    </div>
                    {{end}}
                </div>
                <div class="related-card-body">
                    <h3>{{.Title}}</h3>
                    <p>{{truncate .Excerpt 120}}</p>
                    <span class="related-card-link">{{T $.Ctx "btn_learn_more"}} <span aria-hidden="true">→</span></span>
                </div>
            </a>
            {{end}}
        </div>
    </div>
</section>
{{end}}
{{end}}
