{{define "content"}}
<!-- Page Banner -->
<section class="page-banner page-banner-blog">
    <span class="banner-watermark">{{T $.Ctx "page_title_news_blog"}}</span>
    <div class="container">
        <span class="section-label">{{.Post.Category.Name}}</span>
        <h1>{{.Post.Title}}</h1>
        <div class="post-meta-banner">
            <time>{{formatDate .Post.PublishedAt}}</time>
            {{if .Post.Tags}}
            <span class="post-tags-inline">
                {{range .Post.Tags}}<span class="tag-badge">{{.Name}}</span>{{end}}
            </span>
            {{end}}
        </div>
        <div class="breadcrumb">
            <a href="{{langPrefixURL $.Ctx "/"}}">{{T $.Ctx "nav_home"}}</a> <span>/</span> <a href="{{langPrefixURL $.Ctx (archiveURL "post")}}">{{T $.Ctx "nav_news"}}</a> <span>/</span> <span>{{.Post.Title}}</span>
        </div>
    </div>
    <div class="page-banner-accent"></div>
</section>

<section class="section">
    <div class="container">
        <div class="post-layout">
            <article class="post-content">
                {{if .Post.ImageURL}}
                <div class="post-featured-image">
                    {{responsiveImagePriority .Post.ImageURL .Post.Title "" "(max-width: 768px) 100vw, 70vw"}}
                </div>
                {{end}}
                <div class="post-body">
                    {{safeHTML .Post.Content}}
                </div>
                {{if .Post.Tags}}
                <div class="post-tags">
                    <strong>{{T $.Ctx "sidebar_tags"}}:</strong>
                    {{range .Post.Tags}}<a href="{{langPrefixURL $.Ctx (archiveURL "post")}}?tag={{.Slug}}" class="tag-link">{{.Name}}</a>{{end}}
                </div>
                {{end}}
                <div class="post-nav">
                    <a href="{{langPrefixURL $.Ctx (archiveURL "post")}}" class="btn btn-outline">&larr; {{T $.Ctx "btn_back_blog"}}</a>
                </div>
            </article>
            <aside class="post-sidebar">
                <div class="sidebar-widget">
                    <h4>{{T $.Ctx "section_recent_articles"}}</h4>
                    {{range .RecentPosts}}
                    <div class="sidebar-post">
                        <a href="{{langPrefixURL $.Ctx (contentURL . "post")}}">{{.Title}}</a>
                        <time>{{formatDate .PublishedAt}}</time>
                    </div>
                    {{end}}
                </div>
                {{if .Categories}}
                <div class="sidebar-widget">
                    <h4>{{T $.Ctx "sidebar_categories"}}</h4>
                    {{range .Categories}}
                    <a href="{{langPrefixURL $.Ctx (archiveURL "post")}}?category={{.Slug}}" class="sidebar-cat">{{.Name}}</a>
                    {{end}}
                </div>
                {{end}}
                {{if .Tags}}
                <div class="sidebar-widget">
                    <h4>{{T $.Ctx "sidebar_tags"}}</h4>
                    <div class="sidebar-tags">
                        {{range .Tags}}<a href="{{langPrefixURL $.Ctx (archiveURL "post")}}?tag={{.Slug}}" class="tag-badge">{{.Name}}</a>{{end}}
                    </div>
                </div>
                {{end}}
            </aside>
        </div>
    </div>
</section>

{{if .Related}}
<section class="section section-gray">
    <div class="container">
        <div class="text-center" style="margin-bottom:40px;">
            <span class="section-label">{{T $.Ctx "section_related_articles"}}</span>
            <h2>You May Also Like</h2>
        </div>
        <div class="blog-grid">
            {{range .Related}}
            <article class="blog-card">
                <div class="blog-card-image">
                    {{if .ImageURL}}
                    {{responsiveImage .ImageURL .Title "" "(max-width: 768px) 100vw, 33vw" "lazy"}}
                    {{else}}
                    <div class="product-placeholder placeholder-sm">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                    </div>
                    {{end}}
                </div>
                <div class="blog-card-body">
                    <div class="blog-card-meta">
                        <span class="blog-category">{{.Category.Name}}</span>
                        <time>{{formatDate .PublishedAt}}</time>
                    </div>
                    <h3>{{.Title}}</h3>
                    <p>{{truncate .Excerpt 150}}</p>
                    <a href="{{langPrefixURL $.Ctx (contentURL . "post")}}" class="card-link">Read More &rarr;</a>
                </div>
            </article>
            {{end}}
        </div>
    </div>
</section>
{{end}}
{{end}}
