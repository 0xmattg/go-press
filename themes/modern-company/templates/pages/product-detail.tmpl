{{define "content"}}
<!-- Page Banner -->
<section class="page-banner page-banner-products">
    <span class="banner-watermark">{{T $.Ctx "page_title_products"}}</span>
    <div class="container">
        <span class="section-label">{{T $.Ctx "page_label_product_details"}}</span>
        <h1>{{.Product.Title}}</h1>
        <div class="breadcrumb">
            <a href="{{langPrefixURL $.Ctx "/"}}">{{T $.Ctx "nav_home"}}</a> <span>/</span> <a href="{{langPrefixURL $.Ctx "/products"}}">{{T $.Ctx "page_title_products"}}</a> <span>/</span> <span>{{.Product.Title}}</span>
        </div>
    </div>
    <div class="page-banner-accent"></div>
</section>

<section class="section">
    <div class="container">
        <div class="detail-layout">
            <div class="detail-image">
                <div class="gallery-main" id="galleryMain">
                    {{if .Product.ImageURL}}
                    <img src="{{.Product.ImageURL}}" alt="{{.Product.Title}}" id="galleryMainImg">
                    {{else}}
                    <div class="product-placeholder placeholder-lg">
                        <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                    </div>
                    {{end}}
                    <button class="gallery-nav gallery-nav-prev" onclick="galleryPrev()" aria-label="上一张">&#10094;</button>
                    <button class="gallery-nav gallery-nav-next" onclick="galleryNext()" aria-label="下一张">&#10095;</button>
                </div>
                {{if or .Product.GalleryImages .Product.ImageURL}}
                <div class="gallery-thumbs-strip" id="galleryThumbs">
                    {{if .Product.ImageURL}}
                    <div class="gallery-thumb active" onclick="switchGalleryImage(this, '{{.Product.ImageURL}}')">
                        <img src="{{.Product.ImageURL}}" alt="Main">
                    </div>
                    {{end}}
                    {{range .Product.GalleryImages}}
                    <div class="gallery-thumb" onclick="switchGalleryImage(this, '{{.}}')">
                        <img src="{{.}}" alt="Gallery" loading="lazy">
                    </div>
                    {{end}}
                </div>
                {{end}}
            </div>
            <div class="detail-content">
                <h2>{{.Product.Title}}</h2>
                <div class="detail-body">
                    {{safeHTML .Product.Description}}
                </div>
                {{if .Tags}}
                <div class="post-tags">
                    <strong>{{T $.Ctx "sidebar_tags"}}:</strong>
                    {{range .Tags}}<a href="{{langPrefixURL $.Ctx (printf "/tag/%s" .Slug)}}" class="tag-link">{{.Name}}</a>{{end}}
                </div>
                {{end}}
                <div class="detail-actions">
                    <a href="{{langPrefixURL $.Ctx "/contact"}}" class="btn btn-primary">{{T $.Ctx "btn_get_quote"}}</a>
                    <a href="{{langPrefixURL $.Ctx "/products"}}" class="btn btn-outline">{{T $.Ctx "btn_back_products"}}</a>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
function switchGalleryImage(thumb, url) {
    var img = document.getElementById('galleryMainImg');
    if (!img) return;
    img.src = url;
    var thumbs = document.querySelectorAll('.gallery-thumb');
    thumbs.forEach(function(t) { t.classList.remove('active'); });
    thumb.classList.add('active');
}
function galleryNav(dir) {
    var thumbs = Array.prototype.slice.call(document.querySelectorAll('.gallery-thumb'));
    if (thumbs.length <= 1) return;
    var idx = 0;
    thumbs.forEach(function(t, i) { if (t.classList.contains('active')) idx = i; });
    idx = (idx + dir + thumbs.length) % thumbs.length;
    thumbs[idx].click();
}
function galleryPrev() { galleryNav(-1); }
function galleryNext() { galleryNav(1); }
</script>

{{if .Related}}
<section class="section section-gray">
    <div class="container">
        <div class="text-center" style="margin-bottom:40px;">
            <span class="section-label">{{T $.Ctx "section_may_like"}}</span>
            <h2>{{T $.Ctx "section_other_products"}}</h2>
        </div>
        <div class="related-card-grid">
            {{range .Related}}
            <a href="{{langPrefixURL $.Ctx (printf "/products/%s" .Slug)}}" class="related-card">
                <div class="related-card-image">
                    {{if .ImageURL}}
                    {{responsiveImage .ImageURL .Title "" "(max-width: 768px) 100vw, 33vw" "lazy"}}
                    {{else}}
                    <div class="product-placeholder placeholder-sm">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                    </div>
                    {{end}}
                </div>
                <div class="related-card-body">
                    <h3>{{.Title}}</h3>
                    <p>{{truncate .Excerpt 120}}</p>
                    <span class="related-card-link">{{T $.Ctx "btn_view_details"}} <span aria-hidden="true">→</span></span>
                </div>
            </a>
            {{end}}
        </div>
    </div>
</section>
{{end}}
{{end}}
