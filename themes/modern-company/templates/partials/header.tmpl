{{define "header"}}
<!-- Top Info Bar -->
<div class="top-bar">
    <div class="container">
        <div class="top-bar-inner">
            <div class="top-bar-info">
                {{if .Settings.company_email}}<span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    {{.Settings.company_email}}
                </span>{{end}}
                {{if .Settings.company_phone}}<span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    {{.Settings.company_phone}}
                </span>{{end}}
                {{if .Settings.company_whatsapp}}{{$wa := whatsappLink .Settings.company_whatsapp}}<span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/></svg>
                    <a href="{{$wa}}" target="_blank" rel="noopener" class="top-bar-whatsapp-link">{{.Settings.company_whatsapp}}</a>
                </span>{{end}}
                {{if .Settings.company_address}}<span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    {{.Settings.company_address}}
                </span>{{end}}
            </div>
            <div class="top-bar-social">
                {{if .Settings.social_facebook}}<a href="{{.Settings.social_facebook}}" target="_blank" rel="noopener" aria-label="Facebook">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>{{end}}
                {{if .Settings.social_x}}<a href="{{.Settings.social_x}}" target="_blank" rel="noopener" aria-label="X">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>{{end}}
                {{if .Settings.social_youtube}}<a href="{{.Settings.social_youtube}}" target="_blank" rel="noopener" aria-label="YouTube">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                </a>{{end}}
                {{if .Settings.social_wechat}}<a href="javascript:void(0)" aria-label="WeChat" title="{{.Settings.social_wechat}}">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 0 1 .213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 0 0 .167-.054l1.903-1.114a.864.864 0 0 1 .717-.098 10.16 10.16 0 0 0 2.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178A1.17 1.17 0 0 1 4.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178 1.17 1.17 0 0 1-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 0 1 .598.082l1.584.926a.272.272 0 0 0 .14.045c.134 0 .24-.11.24-.245 0-.06-.024-.12-.04-.178l-.325-1.233a.492.492 0 0 1 .177-.554C23.016 18.514 24 16.89 24 15.09c0-3.222-3.004-5.985-7.062-6.232zm-2.89 2.895c.535 0 .969.44.969.982a.976.976 0 0 1-.969.983.976.976 0 0 1-.969-.983c0-.542.434-.982.97-.982zm4.844 0c.535 0 .969.44.969.982a.976.976 0 0 1-.969.983.976.976 0 0 1-.969-.983c0-.542.434-.982.97-.982z"/></svg>
                </a>{{end}}
                {{if .Settings.social_linkedin}}<a href="{{.Settings.social_linkedin}}" target="_blank" rel="noopener" aria-label="LinkedIn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>{{end}}
            </div>
        </div>
    </div>
</div>

<!-- Main Navigation -->
<header class="site-header" id="site-header">
    <nav class="main-nav">
        <div class="container">
            <div class="nav-inner">
                <a href="{{langPrefixURL $.Ctx "/"}}" class="logo">
                    {{$combined := eq (settingOr .Settings "home_logo_combined" "") "1"}}
                    {{$combinedImage := settingOr .Settings "home_logo_combined_image" ""}}
                    {{if and $combined $combinedImage}}
                    <img class="logo-combined" src="{{$combinedImage}}" alt="{{settingOr .Settings "home_logo_text" "Hurricane Techs"}}">
                    {{else}}
                    {{if settingOr .Settings "home_logo_image" ""}}
                    {{responsiveImage (settingOr .Settings "home_logo_image" "") (settingOr .Settings "home_logo_text" "Hurricane Techs") "logo-img" "180px" "eager"}}
                    {{else}}
                    <span class="logo-icon">{{settingOr .Settings "home_logo_glyph" "H"}}</span>
                    {{end}}
                    <span class="logo-text">{{settingOr .Settings "home_logo_text" "Hurricane Techs"}}</span>
                    {{end}}
                </a>
                <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation">
                    <span></span><span></span><span></span>
                </button>
                <ul class="nav-menu" id="primary-nav">
                    {{$headerMenu := menuByLocation "header"}}
                    {{if $headerMenu}}
                        {{range $headerMenu.Items}}
                        <li><a href="{{.URL}}" class="{{if isMenuActive $.ActivePage .URL}}active{{end}}" {{if eq .Target "_blank"}}target="_blank" rel="noopener"{{end}}>{{.Title}}</a></li>
                        {{end}}
                    {{else}}
                    <li><a href="{{langPrefixURL $.Ctx "/"}}" class="{{if eq .ActivePage "home"}}active{{end}}">{{T $.Ctx "nav_home"}}</a></li>
                    <li><a href="{{langPrefixURL $.Ctx "/about"}}" class="{{if eq .ActivePage "about"}}active{{end}}">{{T $.Ctx "nav_about"}}</a></li>
                    <li><a href="{{langPrefixURL $.Ctx (archiveURL "product")}}" class="{{if eq .ActivePage "products"}}active{{end}}">{{T $.Ctx "nav_products"}}</a></li>
                    <li><a href="{{langPrefixURL $.Ctx (archiveURL "showcase")}}" class="{{if eq .ActivePage "showcase"}}active{{end}}">{{T $.Ctx "nav_projects"}}</a></li>
                    <li><a href="{{langPrefixURL $.Ctx (archiveURL "service")}}" class="{{if eq .ActivePage "services"}}active{{end}}">{{T $.Ctx "nav_services"}}</a></li>
                    <li><a href="{{langPrefixURL $.Ctx (archiveURL "post")}}" class="{{if eq .ActivePage "blog"}}active{{end}}">{{T $.Ctx "nav_news"}}</a></li>
                    {{end}}
                    <li class="nav-cta"><a href="{{settingOr .Settings "home_cta_link" "/contact"}}" class="{{if eq .ActivePage "contact"}}active{{end}}">{{settingOr .Settings "home_cta_text" "GET A QUOTE"}}</a></li>
                    {{renderHook "header.nav.after" .}}
                </ul>
            </div>
        </div>
    </nav>
</header>
{{end}}
