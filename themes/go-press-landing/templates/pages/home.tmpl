{{define "content"}}
<!-- ========== HERO ========== -->
<section class="hero" id="hero">
    <div class="hero-bg">
        <div class="grid-lines"></div>
        <div class="hero-orb hero-orb-1"></div>
        <div class="hero-orb hero-orb-2"></div>
        <div class="hero-orb hero-orb-3"></div>
    </div>
    <div class="container hero-content">
        <div class="hero-badge">
            <span class="badge-dot"></span>
            {{settingOr .Settings "home_hero_badge" "Now in Public Beta — v2.0"}}
        </div>
        <h1 class="hero-title">
            {{settingOr .Settings "home_hero_title_1" "Build Smarter."}}<br>
            <span class="gradient-text">{{settingOr .Settings "home_hero_title_2" "Ship Faster."}}</span><br>
            {{settingOr .Settings "home_hero_title_3" "Scale Infinitely."}}
        </h1>
        <p class="hero-sub">
            {{settingOr .Settings "home_hero_subtitle" "NovaPulse AI is the enterprise-grade platform for deploying, monitoring, and scaling machine learning models in production — from prototype to planet-scale."}}
        </p>
        <div class="hero-actions">
            <a href="{{settingOr .Settings "home_hero_btn1_link" "#pricing"}}" class="btn btn-primary btn-lg">
                {{settingOr .Settings "home_hero_btn1_text" "Start Free Trial"}}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="{{settingOr .Settings "home_hero_btn2_link" "#how-it-works"}}" class="btn btn-outline btn-lg">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                {{settingOr .Settings "home_hero_btn2_text" "Watch Demo"}}
            </a>
        </div>
        <div class="hero-metrics">
            <div class="metric">
                <span class="metric-value">{{settingOr .Settings "home_metric_1_value" "99.99%"}}</span>
                <span class="metric-label">{{settingOr .Settings "home_metric_1_label" "Uptime"}}</span>
            </div>
            <div class="metric-divider"></div>
            <div class="metric">
                <span class="metric-value">{{settingOr .Settings "home_metric_2_value" "<2ms"}}</span>
                <span class="metric-label">{{settingOr .Settings "home_metric_2_label" "Latency"}}</span>
            </div>
            <div class="metric-divider"></div>
            <div class="metric">
                <span class="metric-value">{{settingOr .Settings "home_metric_3_value" "500+"}}</span>
                <span class="metric-label">{{settingOr .Settings "home_metric_3_label" "Enterprise Clients"}}</span>
            </div>
            <div class="metric-divider"></div>
            <div class="metric">
                <span class="metric-value">{{settingOr .Settings "home_metric_4_value" "47B+"}}</span>
                <span class="metric-label">{{settingOr .Settings "home_metric_4_label" "Daily Predictions"}}</span>
            </div>
        </div>
    </div>
</section>

<!-- ========== FEATURES ========== -->
<section class="section" id="features">
    <div class="container">
        <div class="section-header">
            <span class="section-badge">{{settingOr .Settings "home_features_badge" "Features"}}</span>
            <h2 class="section-title">{{settingOr .Settings "home_features_title" "Everything You Need to"}} <span class="gradient-text">{{settingOr .Settings "home_features_title_highlight" "Ship ML at Scale"}}</span></h2>
            <p class="section-sub">{{settingOr .Settings "home_features_subtitle" "From model training to production monitoring, NovaPulse covers the complete ML lifecycle."}}</p>
        </div>
        <div class="features-grid">
            {{range .Features}}
            <div class="feature-card reveal">
                <div class="feature-icon">
                    {{if eq .Icon "compute"}}
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6v6H9z"/><path d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 15h3M1 9h3M1 15h3"/></svg>
                    {{else if eq .Icon "scale"}}
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="7.5 4.21 12 6.81 16.5 4.21"/><polyline points="7.5 19.79 7.5 14.6 3 12"/><polyline points="21 12 16.5 14.6 16.5 19.79"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                    {{else if eq .Icon "monitor"}}
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                    {{else if eq .Icon "edge"}}
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                    {{else if eq .Icon "data"}}
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
                    {{else if eq .Icon "security"}}
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
                    {{else}}
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    {{end}}
                </div>
                <h3 class="feature-title">{{.Title}}</h3>
                <p class="feature-desc">{{.Excerpt}}</p>
            </div>
            {{end}}
        </div>
    </div>
</section>

<!-- ========== HOW IT WORKS ========== -->
<section class="section section-dark" id="how-it-works">
    <div class="container">
        <div class="section-header">
            <span class="section-badge">{{settingOr .Settings "home_steps_badge" "How It Works"}}</span>
            <h2 class="section-title">{{settingOr .Settings "home_steps_title" "From Zero to Production"}} <span class="gradient-text">{{settingOr .Settings "home_steps_title_highlight" "in Three Steps"}}</span></h2>
            <p class="section-sub">{{settingOr .Settings "home_steps_subtitle" "No infrastructure expertise required. Connect, deploy, and scale with confidence."}}</p>
        </div>
        <div class="steps-grid">
            <div class="step-card reveal">
                <div class="step-number">01</div>
                <div class="step-line"></div>
                <h3>{{settingOr .Settings "home_step_1_title" "Connect"}}</h3>
                <p>{{settingOr .Settings "home_step_1_desc" "Link your data sources and model registry. We support all major frameworks — PyTorch, TensorFlow, JAX, ONNX, and more."}}</p>
            </div>
            <div class="step-card reveal">
                <div class="step-number">02</div>
                <div class="step-line"></div>
                <h3>{{settingOr .Settings "home_step_2_title" "Deploy"}}</h3>
                <p>{{settingOr .Settings "home_step_2_desc" "Push to production with blue-green and canary deployment strategies. Zero-downtime rollback included. One command, every time."}}</p>
            </div>
            <div class="step-card reveal">
                <div class="step-number">03</div>
                <div class="step-line"></div>
                <h3>{{settingOr .Settings "home_step_3_title" "Scale"}}</h3>
                <p>{{settingOr .Settings "home_step_3_desc" "Auto-scale from prototype traffic to millions of requests per second. Kubernetes-native, cost-optimized, globally distributed."}}</p>
            </div>
        </div>
    </div>
</section>

<!-- ========== CODE PREVIEW ========== -->
<section class="section" id="code-preview">
    <div class="container">
        <div class="code-split">
            <div class="code-text reveal">
                <span class="section-badge">{{settingOr .Settings "home_code_badge" "Developer Experience"}}</span>
                <h2 class="section-title">{{settingOr .Settings "home_code_title" "Deploy a Model"}}<br><span class="gradient-text">{{settingOr .Settings "home_code_title_highlight" "in 4 Lines"}}</span></h2>
                <p class="section-sub" style="text-align:left;max-width:none;">{{settingOr .Settings "home_code_desc" "Our CLI and SDK are designed for speed. No YAML hell, no config nightmares — just ship."}}</p>
                <ul class="check-list">
                    <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>{{settingOr .Settings "home_code_check_1" "Auto-containerisation — no Dockerfile needed"}}</li>
                    <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>{{settingOr .Settings "home_code_check_2" "Built-in A/B testing and traffic splitting"}}</li>
                    <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>{{settingOr .Settings "home_code_check_3" "Real-time logs and metrics out of the box"}}</li>
                    <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>{{settingOr .Settings "home_code_check_4" "Works with any Python framework"}}</li>
                </ul>
            </div>
            <div class="code-block reveal">
                <div class="code-header">
                    <span class="code-dot red"></span>
                    <span class="code-dot yellow"></span>
                    <span class="code-dot green"></span>
                    <span class="code-filename">{{settingOr .Settings "home_code_filename" "deploy.py"}}</span>
                </div>
                <pre><code><span class="kw">import</span> novapulse <span class="kw">as</span> np

model = np.<span class="fn">load</span>(<span class="str">"./model.onnx"</span>)
endpoint = np.<span class="fn">deploy</span>(model, <span class="str">"prod-v2"</span>,
    <span class="param">gpu</span>=<span class="str">"A100"</span>,
    <span class="param">replicas</span>=<span class="num">3</span>,
    <span class="param">autoscale</span>=<span class="kw">True</span>
)

<span class="cmt"># That's it. You're live.</span>
<span class="fn">print</span>(endpoint.url)
<span class="cmt"># → https://api.novapulse.ai/v1/prod-v2</span></code></pre>
            </div>
        </div>
    </div>
</section>

<!-- ========== TESTIMONIALS ========== -->
<section class="section section-dark" id="testimonials">
    <div class="container">
        <div class="section-header">
            <span class="section-badge">{{settingOr .Settings "home_testimonials_badge" "Testimonials"}}</span>
            <h2 class="section-title">{{settingOr .Settings "home_testimonials_title" "Trusted by"}} <span class="gradient-text">{{settingOr .Settings "home_testimonials_title_highlight" "Industry Leaders"}}</span></h2>
            <p class="section-sub">{{settingOr .Settings "home_testimonials_subtitle" "See why engineering teams at the world's most innovative companies choose NovaPulse."}}</p>
        </div>
        <div class="testimonials-grid">
            {{range .Testimonials}}
            <div class="testimonial-card reveal">
                <div class="testimonial-stars">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                </div>
                <blockquote class="testimonial-quote">&ldquo;{{stripTags .Content}}&rdquo;</blockquote>
                <div class="testimonial-author">
                    <div class="author-avatar">{{slice .Title 0 1}}</div>
                    <div>
                        <div class="author-name">{{.Title}}</div>
                        <div class="author-role">{{.Role}}, {{.Company}}</div>
                    </div>
                </div>
            </div>
            {{end}}
        </div>
    </div>
</section>

<!-- ========== PRICING ========== -->
<section class="section" id="pricing">
    <div class="container">
        <div class="section-header">
            <span class="section-badge">{{settingOr .Settings "home_pricing_badge" "Pricing"}}</span>
            <h2 class="section-title">{{settingOr .Settings "home_pricing_title" "Simple,"}} <span class="gradient-text">{{settingOr .Settings "home_pricing_title_highlight" "Transparent"}}</span> Pricing</h2>
            <p class="section-sub">{{settingOr .Settings "home_pricing_subtitle" "Start free, scale as you grow. No hidden fees, no surprises."}}</p>
        </div>
        <div class="pricing-grid">
            {{range .Pricing}}
            <div class="pricing-card{{if .Popular}} pricing-popular{{end}} reveal">
                {{if .Popular}}<div class="popular-badge">Most Popular</div>{{end}}
                <h3 class="pricing-name">{{.Name}}</h3>
                <div class="pricing-price">
                    <span class="price-amount">{{.Price}}</span>
                    {{if .Period}}<span class="price-period">{{.Period}}</span>{{end}}
                </div>
                <ul class="pricing-features">
                    {{range .Features}}
                    <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
                        {{.}}
                    </li>
                    {{end}}
                </ul>
                <a href="#" class="btn {{if .Popular}}btn-primary{{else}}btn-outline{{end}} btn-block">{{.CTA}}</a>
            </div>
            {{end}}
        </div>
    </div>
</section>

<!-- ========== FINAL CTA ========== -->
<section class="cta-section">
    <div class="cta-bg">
        <div class="hero-orb hero-orb-1"></div>
        <div class="hero-orb hero-orb-2"></div>
    </div>
    <div class="container cta-content">
        <h2 class="section-title">{{settingOr .Settings "home_cta_title" "Ready to Accelerate"}}<br><span class="gradient-text">{{settingOr .Settings "home_cta_title_highlight" "Your AI Pipeline?"}}</span></h2>
        <p class="section-sub">{{settingOr .Settings "home_cta_subtitle" "Join 500+ engineering teams already shipping ML at light speed."}}</p>
        <div class="hero-actions" style="justify-content:center;">
            <a href="{{settingOr .Settings "home_cta_btn1_link" "#pricing"}}" class="btn btn-primary btn-lg">
                {{settingOr .Settings "home_cta_btn1_text" "Get Started Free"}}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="{{settingOr .Settings "home_cta_btn2_link" "#"}}" class="btn btn-outline btn-lg">{{settingOr .Settings "home_cta_btn2_text" "Talk to Sales"}}</a>
        </div>
    </div>
</section>
{{end}}
