<style>
.ts-tabs { display:flex; gap:0; border-bottom:2px solid #e2e8f0; margin-bottom:0; overflow-x:auto; background:#fff; border-radius:8px 8px 0 0; }
.ts-tab { padding:0.85rem 1.25rem; border:none; background:none; cursor:pointer; font-size:0.88rem; font-weight:500; color:#64748b; white-space:nowrap; border-bottom:2px solid transparent; margin-bottom:-2px; transition:color .2s,border-color .2s; }
.ts-tab:hover { color:#1e293b; }
.ts-tab.active { color:#3b82f6; border-bottom-color:#3b82f6; font-weight:600; }
.ts-panel { display:none; background:#fff; padding:1.5rem; border-radius:0 0 8px 8px; border:1px solid #e2e8f0; border-top:none; }
.ts-panel.active { display:block; }
.ts-section-title { margin:0 0 0.5rem; font-size:1.05rem; font-weight:600; color:#1e293b; }
.ts-hint { color:#64748b; font-size:0.85rem; margin-bottom:1.25rem; line-height:1.5; }
.ts-field { margin-bottom:1rem; }
.ts-field label { display:block; margin-bottom:0.35rem; font-size:0.85rem; font-weight:500; color:#374151; }
.ts-field input[type="text"],.ts-field textarea,.ts-field select { width:100%; padding:0.55rem 0.75rem; border:1px solid #d1d5db; border-radius:6px; font-size:0.88rem; transition:border-color .2s; font-family:inherit; box-sizing:border-box; }
.ts-field input:focus,.ts-field textarea:focus,.ts-field select:focus { outline:none; border-color:#3b82f6; box-shadow:0 0 0 2px rgba(59,130,246,0.15); }
.ts-field textarea { resize:vertical; }
.ts-grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
.ts-slide-block { border:1px solid #e5e7eb; border-radius:8px; padding:1.25rem; margin-bottom:1rem; background:#fafbfc; }
.ts-slide-title { margin:0 0 1rem; font-size:0.95rem; font-weight:600; color:#475569; }
.ts-save-bar { padding:1rem 1.5rem; background:#fff; border:1px solid #e2e8f0; border-top:none; border-radius:0 0 8px 8px; display:flex; gap:0.75rem; margin-top:-1px; }

/* Color scheme preview options */
.scheme-options { display:grid; grid-template-columns:repeat(auto-fill, minmax(220px, 1fr)); gap:1rem; }
.scheme-option { display:flex; flex-direction:column; border:2px solid #e2e8f0; border-radius:10px; padding:1rem; cursor:pointer; transition:border-color .2s,box-shadow .2s; }
.scheme-option:hover { border-color:#94a3b8; }
.scheme-selected { border-color:#3b82f6; box-shadow:0 0 0 1px #3b82f6; }
.scheme-option input[type="radio"] { display:none; }
.scheme-preview { height:55px; border-radius:6px; position:relative; overflow:hidden; margin-bottom:0.6rem; }
.scheme-preview .scheme-bar { position:absolute; top:0; left:0; right:0; height:18px; }
.scheme-preview .scheme-accent { position:absolute; bottom:8px; left:10px; width:70px; height:22px; border-radius:4px; }
.scheme-indigo { background:#06061a; }
.scheme-indigo .scheme-bar { background:#1a1a3e; }
.scheme-indigo .scheme-accent { background:linear-gradient(135deg,#6366f1,#a855f7); }
.scheme-cyan { background:#061a2a; }
.scheme-cyan .scheme-bar { background:#0c2d4a; }
.scheme-cyan .scheme-accent { background:linear-gradient(135deg,#06b6d4,#0ea5e9); }
.scheme-emerald { background:#061a14; }
.scheme-emerald .scheme-bar { background:#0c3326; }
.scheme-emerald .scheme-accent { background:linear-gradient(135deg,#10b981,#059669); }
.scheme-rose { background:#1a0610; }
.scheme-rose .scheme-bar { background:#330c1f; }
.scheme-rose .scheme-accent { background:linear-gradient(135deg,#f43f5e,#e11d48); }
.scheme-amber { background:#1a1006; }
.scheme-amber .scheme-bar { background:#33200c; }
.scheme-amber .scheme-accent { background:linear-gradient(135deg,#f59e0b,#d97706); }
.scheme-label { font-weight:600; font-size:0.92rem; margin-bottom:0.2rem; }
.scheme-desc { font-size:0.8rem; color:#64748b; line-height:1.4; }

@media (max-width: 768px) { .ts-grid-2 { grid-template-columns:1fr; } .ts-tabs { flex-wrap:wrap; } }
</style>

<script>
document.querySelectorAll('.ts-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
        document.querySelectorAll('.ts-tab').forEach(function(t){ t.classList.remove('active'); });
        document.querySelectorAll('.ts-panel').forEach(function(p){ p.classList.remove('active'); });
        this.classList.add('active');
        document.getElementById('tab-' + this.dataset.tab).classList.add('active');
    });
});
document.querySelectorAll('.scheme-option input[type="radio"]').forEach(function(radio) {
    radio.addEventListener('change', function() {
        document.querySelectorAll('.scheme-option').forEach(function(opt){ opt.classList.remove('scheme-selected'); });
        this.closest('.scheme-option').classList.add('scheme-selected');
    });
});
</script>
