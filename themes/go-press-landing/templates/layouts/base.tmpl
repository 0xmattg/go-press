{{define "base"}}<!DOCTYPE html>
<html lang="{{currentLang .Ctx}}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.Title}} - {{settingOr .Settings "site_name" "GoPress"}}</title>
    {{$siteIcon := settingOr .Settings "site_icon" ""}}
    {{with seoHeadFor .}}{{.}}{{else}}
    <meta name="description" content="{{settingOr $.Settings "site_description" "NovaPulse AI — Enterprise-grade platform for deploying, monitoring, and scaling machine learning models in production."}}">
    {{if $siteIcon}}<link rel="icon" href="{{$siteIcon}}">
    <link rel="apple-touch-icon" href="{{$siteIcon}}">{{end}}
    {{end}}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/static/css/style.css?v=2">
    {{renderHook "theme.head.end" .}}
</head>
<body class="color-{{settingOr .Settings "theme_color_scheme" "indigo"}}">
    {{renderHook "theme.body.open" .}}
    {{template "header" .}}

    <main>
        {{template "content" .}}
    </main>

    {{template "footer" .}}

    <script src="/static/js/main.js?v=1"></script>
    {{renderHook "theme.footer.end" .}}
</body>
</html>{{end}}
