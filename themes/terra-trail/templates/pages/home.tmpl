{{define "content"}}
{{$s := .Settings}}
{{$hero := settingOr $s "home_hero_image" ""}}
{{if not $hero}}{{range .Showcases}}{{if and (not $hero) .ImageURL}}{{$hero = .ImageURL}}{{end}}{{end}}{{end}}
{{if not $hero}}{{$hero = "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1800&h=980&fit=crop&q=84"}}{{end}}

<section class="tt-hero">
    <div class="tt-hero-top">
        <div class="tt-hero-copy">
            <h1>{{settingOr $s "home_hero_title" "Your Next Adventure Awaits"}}</h1>
        </div>
        <div class="tt-hero-aside">
            <p>{{settingOr $s "home_hero_subtitle" "Explore stunning destinations, unique experiences, and unforgettable journeys with TerraTrail."}}</p>
            <a class="tt-primary-btn" href="{{langPrefixURL .Ctx (settingOr $s "home_hero_btn_link" "/products")}}">{{settingOr $s "home_hero_btn_text" "Booking"}}</a>
        </div>
    </div>
    <div class="tt-hero-media">
        <div class="tt-hero-image" style="--hero-image:url('{{$hero}}');"></div>
        <div class="tt-search-panel" role="search" aria-label="Travel search">
            <div class="tt-filter-row">
                <span><small>Location</small>{{settingOr $s "home_filter_1" "Rinjani, Indonesia"}}</span>
                <span><small>Check In</small>{{settingOr $s "home_filter_2" "27 January 2026"}}</span>
                <span><small>Check Out</small>{{settingOr $s "home_filter_3" "30 January 2026"}}</span>
                <span><small>People</small>{{settingOr $s "home_filter_4" "4 People | 1 Child"}}</span>
            </div>
            <a class="tt-search-button" href="{{langPrefixURL .Ctx "/products"}}" aria-label="{{settingOr $s "home_search_button" "Search"}}">⌕</a>
        </div>
    </div>
</section>

{{if .Products}}
<section class="tt-section tt-packages">
    <div class="tt-section-head">
        <span>{{settingOr $s "home_products_label" "Tour Package"}}</span>
        <h2>{{settingOr $s "home_products_title" "Explore Our Exclusive Tour Packages"}}</h2>
        <p>{{settingOr $s "home_products_desc" "Find your perfect getaway with curated tour packages. Adventure, relaxation, or culture - it is all here for you."}}</p>
    </div>
    <div class="tt-package-grid">
        {{range $i, $p := .Products}}
        {{if lt $i 3}}
        <a class="tt-package-card {{if gt $i 0}}tt-package-card-slim{{end}}" href="{{langPrefixURL $.Ctx (printf "/products/%s" $p.Slug)}}">
            <div class="tt-card-media">
                {{if $p.ImageURL}}{{responsiveImage $p.ImageURL $p.Title "" "(max-width: 768px) 88vw, 25vw" "lazy"}}{{end}}
                <em>Mountain</em>
            </div>
            <div class="tt-package-copy">
                <div class="tt-card-title-row">
                    <h3>{{$p.Title}}</h3>
                    <span>★ 5.5</span>
                </div>
                <strong>{{settingOr $s "package_price" "$456.80"}}</strong>
                <p>{{truncate $p.Excerpt 96}}</p>
                <small>Booking</small>
            </div>
        </a>
        {{end}}
        {{end}}
        {{range $i, $p := .Products}}
        {{if eq $i 3}}
        <a class="tt-package-more" href="{{langPrefixURL $.Ctx (printf "/products/%s" $p.Slug)}}" aria-label="{{$p.Title}}">
            <div class="tt-card-media">
                {{if $p.ImageURL}}{{responsiveImage $p.ImageURL $p.Title "" "(max-width: 768px) 42vw, 12vw" "lazy"}}{{end}}
            </div>
            <span>↗</span>
        </a>
        {{end}}
        {{end}}
    </div>
</section>
{{end}}

<section class="tt-section tt-experience">
    <div class="tt-experience-mosaic">
        <div class="tt-step-card">
            <div>
                <h2>{{settingOr $s "home_step_title" "Every Step of the Way"}}</h2>
                <p>{{settingOr $s "home_step_desc" "Travel with ease and comfort. From private transfers to group tours, we ensure seamless transportation throughout your journey."}}</p>
            </div>
            <a href="{{langPrefixURL .Ctx "/services"}}" aria-label="View transport">↗</a>
        </div>
        <div class="tt-road-card">
            <div class="tt-card-media">
                {{if .Showcases}}{{range $i, $item := .Showcases}}{{if eq $i 0}}{{if $item.ImageURL}}{{responsiveImage $item.ImageURL $item.Title "" "(max-width: 768px) 88vw, 42vw" "lazy"}}{{end}}{{end}}{{end}}{{end}}
            </div>
        </div>
        {{if .Showcases}}
        <a class="tt-side-trip-card" href="{{langPrefixURL .Ctx "/showcase"}}" aria-label="View destinations">
            <div class="tt-card-media">
                {{range $i, $item := .Showcases}}{{if eq $i 1}}{{if $item.ImageURL}}{{responsiveImage $item.ImageURL $item.Title "" "(max-width: 768px) 40vw, 12vw" "lazy"}}{{end}}{{end}}{{end}}
            </div>
            <span>↗</span>
        </a>
        {{end}}
    </div>
    <div class="tt-transport-panel">
        <span>{{settingOr $s "home_transport_label" "Transport"}}</span>
        <h2>{{settingOr $s "home_services_title" "Effortless Travel"}}</h2>
        <div class="tt-transport-list">
            {{range $i, $svc := .Services}}
            {{if lt $i 3}}
            <a class="tt-transport-item {{if eq $i 0}}active{{end}}" href="{{langPrefixURL $.Ctx (printf "/services/%s" $svc.Slug)}}">
                <i>{{if eq $i 0}}✈{{else if eq $i 1}}▣{{else}}⌁{{end}}</i>
                <span><strong>{{$svc.Title}}</strong><small>{{truncate $svc.Excerpt 82}}</small></span>
            </a>
            {{end}}
            {{end}}
        </div>
    </div>
</section>

{{if .Showcases}}
<section class="tt-section tt-guide-strip">
    <div class="tt-guide-copy">
        <h2>{{settingOr $s "home_showcase_title" "Guides, routes, and hidden mountain moments"}}</h2>
        <p>{{settingOr $s "home_showcase_subtitle" "More than 100 local guides are ready to accompany and assist you on your journey."}}</p>
        <a class="tt-outline-btn" href="{{langPrefixURL .Ctx "/showcase"}}">{{settingOr $s "home_showcase_btn" "Meet Guides"}}</a>
    </div>
    <div class="tt-guide-stack">
        {{range $i, $item := .Showcases}}
        {{if lt $i 2}}
        <a class="tt-guide-card" href="{{langPrefixURL $.Ctx (printf "/showcase/%s" $item.Slug)}}">
            <div class="tt-card-media">{{if $item.ImageURL}}{{responsiveImage $item.ImageURL $item.Title "" "(max-width: 768px) 70vw, 18vw" "lazy"}}{{end}}</div>
            <strong>{{$item.Title}}</strong>
            <span>{{$item.Location}}</span>
        </a>
        {{end}}
        {{end}}
    </div>
    <div class="tt-guide-offer">
        <small>{{settingOr $s "home_nearby_metric" "135+"}}</small>
        <span>{{settingOr $s "home_nearby_label" "Event Collaboration"}}</span>
        <a href="{{langPrefixURL .Ctx "/contact"}}">↗</a>
    </div>
</section>
{{end}}
{{end}}
