{{define "content"}}
<section class="tt-detail-hero">
    <span>Transport</span>
    <h1>{{.Service.Title}}</h1>
    <p>{{.Service.Excerpt}}</p>
</section>

<section class="tt-detail-layout">
    <article class="tt-detail-card">
        {{if .Service.ImageURL}}<div class="tt-detail-media">{{responsiveImagePriority .Service.ImageURL .Service.Title "" "(max-width: 768px) 100vw, 62vw"}}</div>{{end}}
        <div class="tt-richtext">{{safeHTML .Service.Description}}</div>
    </article>
    <aside class="tt-detail-aside">
        <h3>More transport</h3>
        {{range .Related}}<a href="{{langPrefixURL $.Ctx (contentURL . "service")}}">{{.Title}} <span>→</span></a>{{end}}
    </aside>
</section>
{{end}}
