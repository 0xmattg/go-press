{{define "header"}}
{{$s := .Settings}}
<header class="tt-header">
    <a class="tt-brand" href="{{langPrefixURL .Ctx "/"}}" aria-label="{{settingOr $s "company_name" "TerraTrail"}} home">
        {{$logoImage := settingOr $s "home_logo_image" ""}}
        {{if $logoImage}}
        <img class="tt-brand-image" src="{{$logoImage}}" alt="" aria-hidden="true">
        {{else}}
        <span class="tt-brand-mark" aria-hidden="true"></span>
        {{end}}
        {{settingOr $s "home_logo_text" "TerraTrail"}}
    </a>
    <button class="tt-nav-toggle" type="button" aria-label="Open navigation" aria-expanded="false">
        <span></span><span></span>
    </button>
    <nav class="tt-nav" aria-label="Primary navigation">
        <ul class="tt-nav-list">
            <li><a class="{{if isMenuURLActive .Ctx "/"}}active{{end}}" href="{{langPrefixURL .Ctx "/"}}">{{settingOr $s "nav_home" "Home"}}</a></li>
            <li><a class="{{if isMenuURLActive .Ctx (archiveURL "product")}}active{{end}}" href="{{langPrefixURL .Ctx (archiveURL "product")}}">{{settingOr $s "nav_process" "Tour"}}</a></li>
            <li><a class="{{if isMenuURLActive .Ctx "/about"}}active{{end}}" href="{{langPrefixURL .Ctx "/about"}}">{{settingOr $s "nav_about" "About Us"}}</a></li>
            <li><a class="{{if isMenuURLActive .Ctx "/contact"}}active{{end}}" href="{{langPrefixURL .Ctx "/contact"}}">{{settingOr $s "nav_contact" "Contact Us"}}</a></li>
            <li><a class="{{if isMenuURLActive .Ctx (archiveURL "showcase")}}active{{end}}" href="{{langPrefixURL .Ctx (archiveURL "showcase")}}">{{settingOr $s "nav_showcase" "Destinations"}}</a></li>
            <li><a class="{{if isMenuURLActive .Ctx (archiveURL "service")}}active{{end}}" href="{{langPrefixURL .Ctx (archiveURL "service")}}">{{settingOr $s "nav_services" "Transport"}}</a></li>
            <li><a class="{{if isMenuURLActive .Ctx (archiveURL "post")}}active{{end}}" href="{{langPrefixURL .Ctx (archiveURL "post")}}">{{settingOr $s "nav_blog" "Journal"}}</a></li>
            {{renderHook "header.nav.after" .}}
        </ul>
    </nav>
</header>
{{end}}
